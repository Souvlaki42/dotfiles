{
  "edit_predictions": {
    "provider": "zed",
  },
  "icon_theme": "Catppuccin Mocha",
  "disable_ai": false,
  "profiles": {
    "Disable AI": {
      "disable_ai": true,
    },
  },
  "minimap": {
    "show": "never",
  },
  "soft_wrap": "editor_width",
  "inlay_hints": {
    "enabled": true,
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "vtsls": {
          "experimental": {
            "maxInlayHintLength": 30,
          },
        },
      },
    },
    "biome": {
      "settings": {
        "require_config_file": true,
      },
    },
  },
  "buffer_line_height": {
    "custom": 1.4,
  },
  "base_keymap": "VSCode",
  "vim_mode": true,
  "ui_font_size": 16.0,
  "buffer_font_size": 16.0,
  "autosave": "on_focus_change",
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Mocha",
  },
  "project_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "button": false,
  },
  "git_panel": {
    "button": false,
  },
  "outline_panel": {
    "button": false,
  },
  "tab_bar": {
    "show": true,
  },
  "relative_line_numbers": "enabled",
  "toolbar": { "breadcrumbs": false, "quick_actions": false },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "ui_font_family": ".SystemUIFont",
  "terminal": {
    "font_size": 14.0,
  },
  "title_bar": {
    "show_branch_icon": false,
    "show_branch_name": false,
    "show_project_items": false,
    "show_onboarding_banner": false,
    "show_user_picture": false,
    "show_sign_in": false,
    "show_menus": false,
  },
  "current_line_highlight": "none",
  "format_on_save": "on",
  "tab_size": 2,
  "languages": {
    "GDScript": {
      "formatter": {
        "external": {
          "command": "gdscript-formatter",
          "arguments": ["--safe"],
        },
      },
    },
    "CSS": {
      "language_servers": ["tailwindcss-language-server"],
    },
    "Markdown": {
      "language_servers": ["!gdscript"],
    },
  },
  "code_actions_on_format": {
    "source.fixAll.biome": true,
    "source.organizeImports.biome": true,
    "source.addMissingImports.ts": true,
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/*.gd.uid",
    "**/*.import",
  ],
}
